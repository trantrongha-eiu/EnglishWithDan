# EnglishWithDan backend — environment variable reference (Phase 11).
# Copy to backend/.env and fill in real values. Never commit the real
# .env file — it's already in .gitignore, and this repo has a documented
# history of an old .env leak (see docs/ENVIRONMENT_VARIABLES.md and
# docs/RUNBOOK.md's Secret Rotation section for full context and status).
#
# See backend/config/index.js for exactly how each of these is read —
# most third-party integrations degrade gracefully (feature disabled,
# not a crash) when their variables are left unset, matching this app's
# existing startup-log behavior. Full descriptions: docs/ENVIRONMENT_VARIABLES.md

# ── Core (required) ──────────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db-name>
JWT_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">

# ── CORS / public URLs ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ── Cloudinary (file uploads — avatars, audio, images, PDFs) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI grading (optional — features degrade gracefully if unset) ─
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ── Google OAuth login (optional — login form still works via
#    email/password if these are unset; only the "Sign in with Google"
#    button is disabled) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (password-reset OTP delivery, writing-graded notifications —
#    optional, but forgot-password won't actually deliver an email
#    without one of these configured) ──
EMAIL_USER=
EMAIL_PASS=
RESEND_API_KEY=
